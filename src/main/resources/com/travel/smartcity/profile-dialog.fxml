<!--                               HBox.hgrow="ALWAYS"/>-->
<!--                <TextField fx:id="newPasswordFieldVisible"-->
<!--                           visible="false" managed="false"-->
<!--                           HBox.hgrow="ALWAYS"/>-->
<!--                <CheckBox fx:id="showNewPassword"-->
<!--                          text="Show"/>-->
<!--            </HBox>-->

            <!-- CURRENT PASSWORD row -->
            <Label text="Current Password:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <StackPane GridPane.rowIndex="2" GridPane.columnIndex="1"
                       alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                <!-- masked field -->
                <PasswordField fx:id="currentPasswordField"
                               promptText="••••••••"
                               StackPane.alignment="CENTER_LEFT" prefWidth="100"/>
                <!-- plain‐text fallback -->
                <TextField   fx:id="currentPasswordFieldPlain"
                             visible="false" managed="false"
                             StackPane.alignment="CENTER_LEFT" prefWidth="100"/>
                <!-- eye toggle -->
                <Button fx:id="toggleCurrentPasswordBtn"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        onAction="#onToggleCurrentPassword">
                    <graphic>
                        <ImageView fx:id="currentEyeIcon"
                                   fitWidth="16" fitHeight="16" preserveRatio="true">
                            <image>
                                <Image url="@images/eye-closed.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
            </StackPane>

            <!-- NEW PASSWORD row -->
            <Label text="New Password:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <StackPane GridPane.rowIndex="3" GridPane.columnIndex="1"
                       alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                <PasswordField fx:id="newPasswordField"
                               promptText="••••••••"
                               StackPane.alignment="CENTER_LEFT" prefWidth="100"/>
                <TextField   fx:id="newPasswordFieldPlain"
                             visible="false" managed="false"
                             StackPane.alignment="CENTER_LEFT" prefWidth="100"/>
                <Button fx:id="toggleNewPasswordBtn"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        onAction="#onToggleNewPassword">
                    <graphic>
                        <ImageView fx:id="newEyeIcon"
                                   fitWidth="16" fitHeight="16" preserveRatio="true">
                            <image>
                                <Image url="@images/eye-closed.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
            </StackPane>


        </GridPane>

        <!-- spacer to push buttons down a bit -->
        <Region prefHeight="10"/>
        <HBox spacing="20" alignment="CENTER_RIGHT">
            <Button fx:id="addBtn"
                    text="Save"
                    onAction="#handleSave"
                    style="-fx-background-color: black; -fx-text-fill: white; -fx-pref-width:80px;"/>
            <Button fx:id="backBtn"
                    text="Back"
                    onAction="#handleBack"
                    style="-fx-background-color: black; -fx-text-fill: white; -fx-pref-width:80px;"/>
        </HBox>

    </VBox>
    <!-- RIGHT: illustration -->
    <ImageView fitWidth="300" preserveRatio="true">
        <image>
            <!-- make sure this file actually exists under resources/com/travel/smartcity/images -->
            <Image url="@images/pro.jpeg"/>
        </image>
    </ImageView>
</HBox>