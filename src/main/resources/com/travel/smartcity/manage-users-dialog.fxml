<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.travel.smartcity.controller.UserManagementController"
            prefHeight="600.0" prefWidth="650.0">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- Top label -->
    <top>
        <Label text="Manage Users"
               style="-fx-font-size: 20px;">
            <padding>
                <Insets top="5" right="5" bottom="5" left="5"/>
            </padding>
        </Label>
    </top>

    <center>
        <VBox spacing="10">
            <!-- Table of users -->
            <TableView fx:id="userTable" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colUserId"   text="ID"       prefWidth="50"/>
                    <TableColumn fx:id="colUsername" text="Username" prefWidth="150"/>
                    <TableColumn fx:id="colEmail"    text="Email"    prefWidth="200"/>
                    <TableColumn fx:id="colIsAdmin"  text="Is Admin" prefWidth="80"/>
                </columns>
            </TableView>

            <!-- Form to add new user and toggle role -->
            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="20"/>
                    <ColumnConstraints percentWidth="30"/>
                    <ColumnConstraints percentWidth="20"/>
                    <ColumnConstraints percentWidth="30"/>
                </columnConstraints>

                <Label text="Username:"  GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="usernameField"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="Email:"     GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="emailField"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="3"/>

                <Label text="Password:"  GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <PasswordField fx:id="passwordField"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="1"/>

                <Label text="Is Admin?"  GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <CheckBox fx:id="isAdminCheckbox"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="3"/>
            </GridPane>

            <!-- spacer to push buttons down a bit -->
            <Region prefHeight="10"/>
            <!-- Buttons -->
            <HBox spacing="15" alignment="CENTER">
                <Button text="Add User"     onAction="#handleAddUser" style="-fx-background-color: black; -fx-text-fill: white; -fx-pref-width:120px;"/>
                <Button text="Update User"  onAction="#handleUpdateUser" style="-fx-background-color: black; -fx-text-fill: white; -fx-pref-width:120px;"/>
                <Button text="Delete User"  onAction="#handleDeleteUser" style="-fx-background-color: black; -fx-text-fill: white; -fx-pref-width:120px;"/>
                <Button fx:id="backBtn" text="Back" onAction="#handleBack" style="-fx-background-color: black; -fx-text-fill: white; -fx-pref-width:120px;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
