<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<!-- root container -->
<HBox xmlns="http://javafx.com/javafx/20"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.travel.smartcity.controller.UserPersonalDetailsController"
      spacing="20" alignment="CENTER"
      style="-fx-background-color: white;"
      prefWidth="700" prefHeight="450">

    <!-- define non-Node objects -->
    <fx:define>
        <!-- ToggleGroup is NOT a Node, so define it here -->
        <ToggleGroup fx:id="genderGroup"/>
    </fx:define>

    <!-- LEFT: your form -->
    <VBox spacing="30" HBox.hgrow="ALWAYS">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Label text="Add Personal Details"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <GridPane hgap="20" vgap="30">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT"
                                   percentWidth="30"/>
                <ColumnConstraints hgrow="ALWAYS"
                                    percentWidth="70"/>
            </columnConstraints>

            <!-- other rows omitted for brevity… -->


            <!-- COUNTRY row -->
            <Label text="Country:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="countryField"
                       promptText="e.g. United States"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <!-- PHONE row -->
            <Label text="Phone:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="phoneField"
                       promptText="+1-202-555-0114"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <!-- ADDRESS row -->
            <Label text="Address:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextArea fx:id="addressArea"
                      prefRowCount="3"
                      wrapText="true"
                      promptText="Street, City, ZIP..."
                      GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <!-- Gender row -->
            <Label text="Gender:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <HBox spacing="10" GridPane.rowIndex="4" GridPane.columnIndex="1">
                <!-- *no* <ToggleGroup> here! -->
                <children>
                    <RadioButton fx:id="maleBtn"
                                 text="Male"
                                 toggleGroup="$genderGroup"/>
                    <RadioButton fx:id="femaleBtn"
                                 text="Female"
                                 toggleGroup="$genderGroup"/>
                </children>
            </HBox>
        </GridPane>

        <HBox spacing="20" alignment="CENTER_RIGHT">
            <Button fx:id="addBtn"
                    text="Save"
                    onAction="#handleAdd"
                    style="-fx-background-color: black; -fx-text-fill: white; -fx-pref-width:80px;"/>
            <Button fx:id="backBtn"
                    text="Back"
                    onAction="#handleBack"
                    style="-fx-background-color: black; -fx-text-fill: white; -fx-pref-width:80px;"/>
        </HBox>
    </VBox>

    <!-- RIGHT: illustration -->
    <ImageView fitWidth="300" preserveRatio="true">
        <image>
            <!-- make sure this file actually exists under resources/com/travel/smartcity/images -->
            <Image url="@images/woman.jpeg"/>
        </image>
    </ImageView>
</HBox>
