<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.shape.Circle?>
<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx/20"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.travel.smartcity.controller.DashboardController"
            stylesheets="@css/user-dashboard.css"
            styleClass="root-dash">

    <top>
        <ToolBar style="-fx-background-color: #f0f0f0;">

            <Pane HBox.hgrow="ALWAYS" />

            <!-- avatar dropdown -->
            <MenuButton fx:id="profileMenuButton"
                        text=""    styleClass="avatar-menu-button">
                <graphic>
                    <ImageView fitWidth="32" fitHeight="32" preserveRatio="true">
                        <image>
                            <Image url="@images/avatar.png"/>
                        </image>
                        <clip>
                            <Circle radius="16" centerX="16" centerY="16"/>
                        </clip>
                    </ImageView>
                </graphic>
                <items>
                    <MenuItem fx:id="usernameItem" disable="true"/>
                    <MenuItem fx:id="emailItem"    disable="true"/>
                    <MenuItem text="Logout"       onAction="#handleLogout"/>
                </items>
            </MenuButton>
        </ToolBar>
    </top>
    <!-- LEFT: vertical nav -->
    <left>
        <VBox fx:id="navPane" spacing="5" minWidth="200"
              style="-fx-background-color: #001f4d; -fx-padding: 10;">
            <Label text="Dashboard"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-padding: 0 0 10 0;"/>
            <Button text="Add Personal Details"    onAction="#goToAddPersonal"    styleClass="nav-button"/>
            <Button text="View Profile"            onAction="#updateProfile" styleClass="nav-button"/>
            <Button text="View Hotels"           onAction="#handleHotels" styleClass="nav-button"/>
            <Button text="View Parks"            onAction="#handleParks"   styleClass="nav-button"/>
            <Button text="View Libraries"        onAction="#handleLibraries" styleClass="nav-button"/>
            <Button text="View Destinations"     onAction="#handleDestinations"    styleClass="nav-button"/>
            <Button text="View Restaurants"      onAction="#handleRestaurants"    styleClass="nav-button"/>
            <Button text="View Bookings"           onAction="#viewBookings"     styleClass="nav-button"/>
            <Button text="View Jobs"              onAction="#handleJobs"   styleClass="nav-button"/>


            <Button text="View Package"            onAction="#goToViewPackage"    styleClass="nav-button"/>

            <Button text="Search"                   onAction="#goToSearch"        styleClass="nav-button"/>
        </VBox>
    </left>

    <!-- CENTER: background image + overlaid title -->
    <center>
        <StackPane fx:id="centerStackPane">
            <!-- full-bleed background -->
            <ImageView fitWidth="1720" fitHeight="1200" preserveRatio="false">
                <image>
                    <Image url="@images/city-back.jpg"/>
                </image>
            </ImageView>
            <!-- overlay title -->
            <Label text="Travel and Tourism Management System"
                   style="-fx-text-fill: white;
                    -fx-font-size: 36px;
                    -fx-font-weight: bold;
                    -fx-effect: dropshadow( gaussian , rgba(0,0,0,0.8), 4,0,0,2 );"/>
        </StackPane>

    </center>

</BorderPane>

