<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/20"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.travel.smartcity.controller.UserPersonalDetailsController"
      spacing="10">

    <!-- 1) Now use a nested padding element -->
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <fx:define>
        <!-- ToggleGroup is NOT a Node, so define it here -->
        <ToggleGroup fx:id="genderGroup"/>
    </fx:define>

    <Label text="Add Personal Details" style="-fx-font-size: 20px;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Username:"  GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="usernameField"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="ID:"        GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="idCombo"
                  GridPane.rowIndex="1" GridPane.columnIndex="1">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Passport"/>
                    <String fx:value="Driver’s License"/>
                    <String fx:value="National ID"/>
                </FXCollections>
            </items>
        </ComboBox>

        <Label text="Number:"    GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="numberField"
                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Name:"      GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField"
                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Gender:"    GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <HBox spacing="10" GridPane.rowIndex="4" GridPane.columnIndex="1">
            <RadioButton fx:id="maleBtn"   text="Male"   toggleGroup="$genderGroup"/>
            <RadioButton fx:id="femaleBtn" text="Female" toggleGroup="$genderGroup"/>
        </HBox>

        <!-- add more rows as needed -->
    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Add"  onAction="#handleAdd"/>
        <Button text="Back" onAction="#handleBack"/>
    </HBox>
</VBox>
