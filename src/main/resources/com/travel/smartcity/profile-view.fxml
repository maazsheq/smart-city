<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<HBox xmlns="http://javafx.com/javafx/20"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.travel.smartcity.controller.ProfileController"
      spacing="20" alignment="CENTER"
      style="-fx-background-color: white;"
      prefWidth="900" prefHeight="450">
    <!--    <children>-->
    <!--        <Label text="Username:" layoutX="200" layoutY="150"/>-->
    <!--        <TextField fx:id="userNameField" layoutX="300" layoutY="150"/>-->
    <!--        <Label text="New Password:" layoutX="200" layoutY="200"/>-->
    <!--        <PasswordField fx:id="newPasswordField" layoutX="300" layoutY="200"/>-->
    <!--        <Button text="Save" layoutX="350" layoutY="250"-->
    <!--                onAction="#handleSave"/>-->
    <!--        <Button text="Back to Dasboard" layoutX="450" layoutY="330"-->
    <!--                onAction="#goToDashboard"/>-->
    <!--    </children>-->

    <!-- LEFT: your form -->
    <VBox spacing="30" HBox.hgrow="ALWAYS">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Label text="Add Personal Details"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <GridPane hgap="15" vgap="15"
        alignment="TOP_RIGHT">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- other rows omitted for brevity… -->


            <!-- COUNTRY row -->
            <Label text="Username:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                   layoutX="200" layoutY="150"/>
            <TextField fx:id="userNameField"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <!-- PASSWORD row -->

            <Label text="Current Password:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <HBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                <!-- masked field -->
                <PasswordField fx:id="currentPasswordField"
                               promptText="••••••••"
                               HBox.hgrow="ALWAYS"/>
                <!-- plain‐text field, hidden by default -->
                <TextField fx:id="currentPasswordFieldVisible"
                           visible="false" managed="false"
                           HBox.hgrow="ALWAYS"/>
                <CheckBox fx:id="showCurrentPassword"
                          text="Show"/>
            </HBox>

            <!-- NEW PASSWORD row -->
            <Label text="New Password:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <HBox spacing="5" GridPane.rowIndex="3" GridPane.columnIndex="1">
                <PasswordField fx:id="newPasswordField"
                               promptText="••••••••"
                               HBox.hgrow="ALWAYS"/>
                <TextField fx:id="newPasswordFieldVisible"
                           visible="false" managed="false"
                           HBox.hgrow="ALWAYS"/>
                <CheckBox fx:id="showNewPassword"
                          text="Show"/>
            </HBox>

        </GridPane>

        <!-- spacer to push buttons down a bit -->
        <Region prefHeight="10"/>
        <HBox spacing="20" alignment="CENTER_RIGHT">
            <Button fx:id="addBtn"
                    text="Save"
                    onAction="#handleSave"
                    style="-fx-background-color: black; -fx-text-fill: white; -fx-pref-width:80px;"/>
            <Button fx:id="backBtn"
                    text="Back"
                    onAction="#handleBack"
                    style="-fx-background-color: black; -fx-text-fill: white; -fx-pref-width:80px;"/>
        </HBox>

    </VBox>
    <!-- RIGHT: illustration -->
    <ImageView fitWidth="300" preserveRatio="true">
        <image>
            <!-- make sure this file actually exists under resources/com/travel/smartcity/images -->
            <Image url="@images/pro.jpeg"/>
        </image>
    </ImageView>
</HBox>