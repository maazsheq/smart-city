<GridPane hgap="10" vgap="10"
          xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.travel.smartcity.controller.PaymentController">
<Label text="Card Number:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
<TextField fx:id="cardField" GridPane.rowIndex="0" GridPane.columnIndex="1" />
<Label text="Expiry:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
<TextField fx:id="expiryField" GridPane.rowIndex="1" GridPane.columnIndex="1" />
<Button text="Pay" GridPane.rowIndex="2" GridPane.columnIndex="1"
        onAction="#handlePayment" />
    <Button text="Back to Dasboard" layoutX="450" layoutY="330"
            onAction="#goToDashboard" />
</GridPane>