<BorderPane xmlns="http://javafx.com/javafx/20"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.travel.smartcity.controller.SearchController">

    <top>
        <HBox spacing="10" alignment="CENTER">
            <TextField fx:id="searchField" promptText="Search places..." />
            <Button text="Go" onAction="#handleSearch"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="resultTable">
            <columns>
                <TableColumn fx:id="nameCol" text="Name"/>
                <TableColumn fx:id="typeCol" text="Type"/>
                <TableColumn fx:id="addressCol" text="Address"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
